#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

if [[ "$(uname -s)" != "Linux" ]]; then
  exec ssh victor@192.168.1.150 \
    'cd "$HOME/d3500-capture" && git pull --ff-only && ./start-pi-cam'
fi

export PATH="$HOME/.local/bin:$PATH"
export D3500_HOST=0.0.0.0
export D3500_PORT=8000
export D3500_GPHOTO2=/usr/bin/gphoto2

mkdir -p captures

exec uv run uvicorn app.main:app --host 0.0.0.0 --port 8000
